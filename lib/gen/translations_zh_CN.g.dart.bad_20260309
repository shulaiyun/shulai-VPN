/// Flat map(s) containing all translations.
/// Only for edge cases! For simple maps, use the map function of this library.
extension on TranslationsZhCn {
  dynamic _flatMapFunction(String path) {
    switch (path) {
      case 'common.appTitle':
        return 'Hiddify';
      case 'common.start':
        return '丕亘丿兀';
      case 'common.version':
        return '丕賱廿氐丿丕乇';
      case 'common.ok':
        return '賲賵丕賮賯';
      case 'common.cancel':
        return '廿賱睾丕亍';
      case 'common.kContinue':
        return '賲鬲丕亘毓丞';
      case 'common.showMore':
        return '毓乇囟 丕賱賲夭賷丿';
      case 'common.showLess':
        return '毓乇囟 兀賯賱';
      case 'common.filter':
        return '鬲氐賮賷丞';
      case 'common.all':
        return '丕賱賰賱';
      case 'common.pause':
        return '廿賷賯丕賮 賲丐賯鬲';
      case 'common.resume':
        return '丕爻鬲卅賳丕賮';
      case 'common.clear':
        return '賲爻丨';
      case 'common.close':
        return '廿睾賱丕賯';
      case 'common.auto':
        return '鬲賱賯丕卅賷';
      case 'common.manually':
        return '賷丿賵賷';
      case 'common.name':
        return '丕賱丕爻賲';
      case 'common.url':
        return '丕賱乇丕亘胤';
      case 'common.add':
        return '廿囟丕賮丞';
      case 'common.clipboard':
        return '丕賱丨丕賮馗丞';
      case 'common.addToClipboard':
        return '廿囟丕賮丞 廿賱賶 丕賱丨丕賮馗丞';
      case 'common.scanQr':
        return '賲爻丨 乇賲夭 QR';
      case 'common.free':
        return '賲噩丕賳賷';
      case 'common.warp':
        return 'WARP';
      case 'common.fragment':
        return 'Fragment';
      case 'common.help':
        return '賲爻丕毓丿丞';
      case 'common.save':
        return '丨賮馗';
      case 'common.update':
        return '鬲丨丿賷孬';
      case 'common.share':
        return '賲卮丕乇賰丞';
      case 'common.edit':
        return '鬲毓丿賷賱';
      case 'common.delete':
        return '丨匕賮';
      case 'common.discard':
        return '鬲噩丕賴賱';
      case 'common.import':
        return '丕爻鬲賷乇丕丿';
      case 'common.export':
        return '鬲氐丿賷乇';
      case 'common.later':
        return '賱丕丨賯賸丕';
      case 'common.ignore':
        return '鬲噩丕賴賱';
      case 'common.quit':
        return '禺乇賵噩';
      case 'common.notSet':
        return '睾賷乇 賲丨丿丿';
      case 'common.hide':
        return '廿禺賮丕亍';
      case 'common.exit':
        return '禺乇賵噩';
      case 'common.reset':
        return '廿毓丕丿丞 鬲毓賷賷賳';
      case 'common.done':
        return '鬲賲';
      case 'common.search':
        return '亘丨孬';
      case 'common.decline':
        return '乇賮囟';
      case 'common.agree':
        return '兀賵丕賮賯';
      case 'common.empty':
        return '賮丕乇睾';
      case 'common.unknown':
        return '睾賷乇 賲毓乇賵賮';
      case 'common.hidden':
        return '賲禺賮賷';
      case 'common.timeout':
        return '丕賳鬲賴賶 丕賱賵賯鬲';
      case 'common.sort':
        return '賮乇夭';
      case 'common.dashboard':
        return '賱賵丨丞 丕賱鬲丨賰賲';
      case 'common.interval.day':
        return ({required num n}) => (_root.$meta.cardinalResolver ?? PluralResolvers.cardinal('zh'))(
          n,
          zero: '',
          one: '賷賵賲 賵丕丨丿',
          two: '賷賵賲丕賳',
          few: '${n} 兀賷丕賲',
          many: '${n} 賷賵賲賸丕',
          other: '${n} 賷賵賲',
        );
      case 'common.interval.hour':
        return ({required num n}) => (_root.$meta.cardinalResolver ?? PluralResolvers.cardinal('zh'))(
          n,
          zero: '',
          one: '爻丕毓丞 賵丕丨丿丞',
          two: '爻丕毓鬲丕賳',
          few: '${n} 爻丕毓丕鬲',
          many: '${n} 爻丕毓丞',
          other: '${n} 爻丕毓丞',
        );
      case 'common.msg.permission.denied':
        return '鬲賲 乇賮囟 丕賱廿匕賳';
      case 'common.msg.export.clipboard.success':
        return '鬲賲鬲 丕賱廿囟丕賮丞 廿賱賶 丕賱丨丕賮馗丞 亘賳噩丕丨';
      case 'common.msg.export.clipboard.failure':
        return '賮卮賱 丕賱賳爻禺 廿賱賶 丕賱丨丕賮馗丞';
      case 'common.msg.export.clipboard.contentTooLarge':
        return '丕賱賲丨鬲賵賶 賰亘賷乇 噩丿賸丕. 丕爻鬲禺丿賲 鬲氐丿賷乇 丕賱賲賱賮 亘丿賱丕賸 賲賳 匕賱賰';
      case 'common.msg.export.file.success':
        return '鬲賲 廿賳卮丕亍 賲賱賮 JSON 亘賳噩丕丨';
      case 'common.msg.export.file.failure':
        return '賮卮賱 廿賳卮丕亍 丕賱賲賱賮';
      case 'common.msg.import.confirm':
        return '鬲兀賰賷丿 丕賱丕爻鬲賷乇丕丿';
      case 'common.msg.import.success':
        return '鬲賲 丕賱丕爻鬲賷乇丕丿 亘賳噩丕丨';
      case 'common.msg.import.failure':
        return '賮卮賱 丕賱丕爻鬲賷乇丕丿';
      case 'intro.banner':
        return '賰賱 賲丕 鬲丨鬲丕噩賴 賱廿賳鬲乇賳鬲 亘賱丕 賯賷賵丿';
      case 'intro.termsAndPolicyCaution':
        return ({required InlineSpanBuilder tap}) => TextSpan(
          children: [
            const TextSpan(text: '亘丕賱丕爻鬲賲乇丕乇貙 兀賳鬲 鬲賵丕賮賯 毓賱賶 '),
            tap(_root.pages.about.termsAndConditions),
          ],
        );
      case 'intro.info':
        return ({required InlineSpanBuilder tap_source, required InlineSpanBuilder tap_license}) => TextSpan(
          children: [
            const TextSpan(text: '氐購賳毓 亘賭 鉂わ笍 亘賵丕爻胤丞 Hiddify - '),
            tap_source('賲賮鬲賵丨 丕賱賲氐丿乇'),
            const TextSpan(text: ' ('),
            tap_license('丕賱乇禺氐丞'),
            const TextSpan(text: ')'),
          ],
        );
      case 'pages.home.title':
        return '丕賱乇卅賷爻賷丞';
      case 'pages.home.quickSettings':
        return '丕賱廿毓丿丕丿丕鬲 丕賱爻乇賷毓丞';
      case 'pages.proxies.title':
        return '丕賱亘乇賵賰爻賷丕鬲';
      case 'pages.proxies.sort':
        return '賮乇夭 丕賱亘乇賵賰爻賷丕鬲';
      case 'pages.proxies.testDelay':
